# App configuration
SECRET_KEY=supersecretjwtkeyforjwttokenschangeinproduction
ACCESS_TOKEN_EXPIRE_MINUTES=1440
PORT=8000

# CORS: comma-separated allowed origins. Use * for development only.
# Example: https://dashboard.example.com,http://localhost:5173
CORS_ORIGINS=*

# Database Configuration (MySQL/Aiven)
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<database>?ssl_ca=<path_to_ca_pem>
# If DATABASE_URL is empty, SQLite fallback (sqlite:///./sentinel.db) will be used.
DATABASE_URL=
DB_SSL_CA_PATH=

# Telegram Integration (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Cloudinary Credentials (For media storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
